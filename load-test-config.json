{
  "scenarios": [
    {
      "name": "Health Check Endpoint",
      "weight": 3,
      "flow": [
        {
          "get": {
            "url": "/health",
            "capture": [
              {
                "json": "$.status",
                "as": "healthStatus"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Secure Data Access",
      "weight": 2,
      "flow": [
        {
          "get": {
            "url": "/secure-data",
            "headers": {
              "Authorization": "Bearer {{ $random.jwt }}"
            }
          }
        }
      ]
    },
    {
      "name": "Audit Log Creation",
      "weight": 1,
      "flow": [
        {
          "post": {
            "url": "/audit-log",
            "headers": {
              "Authorization": "Bearer {{ $random.jwt }}",
              "Content-Type": "application/json"
            },
            "json": {
              "userId": "{{ $random.uuid }}",
              "action": "{{ $random.string }}",
              "resource": "{{ $random.string }}",
              "success": true
            }
          }
        }
      ]
    }
  ],
  "config": {
    "target": "http://localhost:3000",
    "phases": [
      {
        "duration": 60,
        "arrivalRate": 10,
        "name": "Warm up"
      },
      {
        "duration": 300,
        "arrivalRate": 50,
        "name": "Sustained load"
      },
      {
        "duration": 120,
        "arrivalRate": 100,
        "name": "Peak load"
      }
    ],
    "payload": {
      "path": "./payloads/users.csv",
      "fields": ["userId", "jwt"]
    }
  }
}